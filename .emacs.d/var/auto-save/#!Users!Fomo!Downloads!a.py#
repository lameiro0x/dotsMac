#!/usr/bin/env python3
"""
Ejemplo de Python para probar resaltado de sintaxis en Emacs.
Contiene funciones, clases, estructuras de control y tipos básicos.
"""

import math
import sys
from datetime import datetime


# Constantes globales
PI = 3.14159
DEBUG = True


class Circulo:
    """Clase que representa un círculo."""

    def __init__(self, radio: float):
        self.radio = radio

    def area(self) -> float:
        return PI * (self.radio ** 2)

    def perimetro(self) -> float:
        return 2 * PI * self.radio

    def __str__(self):
        return f"Circulo(radio={self.radio})"


def fibonacci(n: int) -> list[int]:
    """Genera los primeros n números de Fibonacci."""
    seq = [0, 1]
    while len(seq) < n:
        seq.append(seq[-1] + seq[-2])
    return se


def saludo(nombre: str = "Mundo") -> str:
    return f"Hola, {nombre}!"


if __name__ == "__main__":
    # Crear un círculo y mostrar sus propiedades
    c = Circulo(5)
    print(c)
    print("Área:", c.area())
    print("Perímetro:", c.perimetro())

    # Probar Fibonacci
    print("Fibonacci(10):", fibonacci(10))

    # Diccionario de ejemplo
    datos = {"usuario": "alice", "edad": 30, "activo": True}
    for clave, valor in datos.items():
        print(f"{clave} → {valor}")

    # Condicional con fecha
    if datetime.now().hour < 12:
        print(saludo("mañana"))
    else:
        print(saludo("tarde"))

    # Comprobación de argumentos
    if DEBUG and len(sys.argv) > 1:
        print("Argumentos recibidos:", sys.argv[1:])
